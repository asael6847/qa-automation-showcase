# Conexión a PostgreSQL (driver async asyncpg).
# En docker-compose el host es el nombre del servicio: "postgres".
DATABASE_URL=postgresql+asyncpg://qa:qa_password@localhost:5432/qa_showcase

# Orígenes permitidos para CORS (el dashboard Next.js en dev).
CORS_ORIGINS=http://localhost:3000,http://localhost:8088

# Comando que ejecuta la suite Playwright para el runner de streaming.
# Por defecto usa pnpm desde la raíz del monorepo.
RUN_TESTS_CMD=pnpm --filter tests test

# Directorio raíz del monorepo (donde vive package.json), relativo o absoluto.
# El runner lo usa como cwd del subprocess.
MONOREPO_ROOT=..
