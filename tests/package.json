{
  "name": "tests",
  "version": "1.0.0",
  "private": true,
  "description": "Suite E2E sobre SauceDemo con patrón Screenplay implementado a mano.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "show-report": "playwright show-report",
    "evidence": "playwright test --config=playwright.evidence.config.ts",
    "evidence:headed": "PW_SLOWMO=600 EVIDENCE_DWELL_MS=800 playwright test --config=playwright.evidence.config.ts --headed",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.19.0",
    "@eslint/js": "^9.17.0"
  }
}
